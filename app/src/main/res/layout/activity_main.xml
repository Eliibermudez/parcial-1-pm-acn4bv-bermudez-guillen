<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F3FA">


    <LinearLayout
        android:id="@+id/contenedorLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/padding_large"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgLogoCampus"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="@dimen/space_md"
            android:adjustViewBounds="true"
            android:contentDescription="@string/logo_campus"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_campus_estudiantil" />

        <Button
            android:id="@+id/btnIngresar"
            android:layout_width="220dp"
            android:layout_height="46dp"
            android:layout_marginTop="80dp"
            android:background="@drawable/bg_button"
            android:elevation="2dp"
            android:text="@string/ingresar"
            android:textColor="@color/colorTextButton"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>