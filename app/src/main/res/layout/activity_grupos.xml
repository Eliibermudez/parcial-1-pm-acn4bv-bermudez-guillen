<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".GruposActivity">

    <!-- Barra superior título -->
    <TextView
        android:id="@+id/tituloGrupos"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/colorPrimary"
        android:gravity="center"
        android:text="@string/titulo_grupos"
        android:textColor="@color/textWhite"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenedor principal -->
    <LinearLayout
        android:id="@+id/contenedorTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_screen"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tituloGrupos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="@dimen/padding_small">

        <TextView
            android:id="@+id/tabBuscarGrupos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/padding_small"
            android:text="@string/buscar_grupos"
            android:background="@color/colorPrimary"
            android:textColor="@color/colorTextButton"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabMisGrupos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_sm"
            android:gravity="center"
            android:padding="@dimen/padding_small"
            android:text="@string/mis_grupos"
            android:background="@color/colorPrimary"
            android:textColor="@color/colorTextButton"
            android:textSize="@dimen/text_regular" />
    </LinearLayout>

    <!-- Lista scrolleable -->
    <ScrollView
        android:id="@+id/scrollGrupos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/margin_screen"
        android:layout_marginEnd="@dimen/margin_screen"
        android:layout_marginBottom="@dimen/margin_between_cards"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/contenedorTabs"
        app:layout_constraintBottom_toTopOf="@id/btnCrearGrupo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contenedorListaGrupos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card grupo 1 -->
            <LinearLayout
                android:id="@+id/cardGrupoBaseDatos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_between_cards"
                android:background="@drawable/bg_card"
                android:textColor="@color/colorTextButton"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grupo_base_datos"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/grupo_base_datos_detalle"
                    android:textColor="@color/textMuted"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/grupo_estado_abierto"
                    android:textColor="@color/colorSuccess"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Card grupo 2 -->
            <LinearLayout
                android:id="@+id/cardGrupoProgramacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grupo_programacion"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/grupo_programacion_detalle"
                    android:textColor="@color/textMuted"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/grupo_estado_cerrado"
                    android:textColor="@color/colorDanger"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Botón crear grupo -->
    <Button
        android:id="@+id/btnCrearGrupo"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_screen"
        android:layout_marginEnd="@dimen/margin_screen"
        android:layout_marginBottom="@dimen/margin_button_bottom"
        android:background="@drawable/bg_button"
        android:text="@string/crear_grupo"
        android:textColor="@color/colorTextButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>