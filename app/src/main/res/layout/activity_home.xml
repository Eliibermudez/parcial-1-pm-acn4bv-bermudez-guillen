<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".HomeActivity">

    <!-- Barra superior -->
    <TextView
        android:id="@+id/tituloHome"
        android:layout_width="0dp"
        android:layout_height="@dimen/topbar_height"
        android:background="@color/colorPrimary"
        android:gravity="center"
        android:text="@string/titulo_home"
        android:textColor="@color/textWhite"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenedor -->
    <LinearLayout
        android:id="@+id/contenedorCards"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_screen"
        android:paddingEnd="@dimen/margin_screen"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/margin_screen"
        app:layout_constraintTop_toBottomOf="@id/tituloHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Card Materias -->
        <LinearLayout
            android:id="@+id/cardMaterias"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_height"
            android:layout_marginBottom="@dimen/margin_between_cards"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/padding_medium">

            <TextView
                android:id="@+id/iconMaterias"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:background="@drawable/bg_icon_purple"
                android:gravity="center"
                android:text="@string/icono_materias"
                android:textSize="@dimen/text_big" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtMaterias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mis_materias"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/text_large"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDetalleMaterias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detalle_materias"
                    android:textColor="@color/textMuted"
                    android:textSize="@dimen/text_medium" />

            </LinearLayout>

        </LinearLayout>

        <!-- Card Grupos -->
        <LinearLayout
            android:id="@+id/cardGrupos"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_height"
            android:layout_marginBottom="@dimen/margin_between_cards"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/padding_medium">

            <TextView
                android:id="@+id/iconGrupos"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:background="@drawable/bg_icon_purple"
                android:gravity="center"
                android:text="@string/icono_grupos"
                android:textSize="@dimen/text_big" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGrupos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grupos_trabajo"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/text_large"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDetalleGrupos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detalle_grupos"
                    android:textColor="@color/textSecondary"
                    android:textSize="@dimen/text_medium" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>